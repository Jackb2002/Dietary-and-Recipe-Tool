<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DietaryApp.Avalonia.Views.IngredientSelectorDialog"
        Title="{Binding WindowTitle}" Width="380" Height="380"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="16" LastChildFill="True">

        <TextBlock DockPanel.Dock="Top" Text="{Binding HintText}"
                   TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12"/>

        <!-- Add row -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBox Grid.Column="0" Text="{Binding NewIngredientText}"
                     Watermark="Ingredient name..." Margin="0,0,6,0"/>
            <Button Grid.Column="1" Content="Add" Command="{Binding AddIngredientCommand}"/>
        </Grid>

        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,10,0,0">
            <Button Content="Remove Selected" Command="{Binding RemoveSelectedCommand}"/>
            <Button Content="Cancel" Click="CancelButton_Click"/>
            <Button Content="Save"   Click="SaveButton_Click" IsDefault="True"/>
        </StackPanel>

        <ListBox ItemsSource="{Binding Ingredients}"
                 SelectedItem="{Binding SelectedIngredient}"/>
    </DockPanel>
</Window>
