<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DietaryApp.Avalonia.Views.LoadingWindow"
        Title="Meal Planner — Loading"
        Width="420" Height="180"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        SystemDecorations="BorderOnly">

    <StackPanel Margin="30" Spacing="16">
        <TextBlock Text="Meal Planner" FontSize="20" FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>
        <ProgressBar x:Name="LoadingBar" Minimum="0" Maximum="100"
                     Value="{Binding Progress}" Height="18"/>
        <TextBlock x:Name="StatusLabel" Text="{Binding StatusMessage}"
                   HorizontalAlignment="Center" Foreground="#555"/>
    </StackPanel>
</Window>
